# Copy to `.env` (which is gitignored) and fill in. The CLI auto-loads `.env`.
#   cp .env.example .env
#
# IMPORTANT: put real keys in `.env`, NOT here. This file is committed; `.env` is not.

# --- LLM provider for generation + judging (indexing/retrieval need no key) ---
# Default provider is Anthropic (Claude). Pick ONE of the setups below.

# 1) Anthropic (default). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 2) OpenAI
# CODERAG_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key

# 3) Any OpenAI-compatible endpoint — OpenRouter (→ Claude/Gemini/Llama/...),
#    Together, Groq, Azure, or local Ollama / LM Studio / vLLM.
# CODERAG_LLM_PROVIDER=openai
# CODERAG_LLM_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...
# CODERAG_GEN_MODEL=anthropic/claude-3.5-sonnet
# (local example: CODERAG_LLM_BASE_URL=http://localhost:11434/v1  OPENAI_API_KEY=ollama
#                 CODERAG_GEN_MODEL=qwen2.5-coder)

# --- Optional model/embedding overrides (defaults are fine) ---
# CODERAG_GEN_MODEL=...
# CODERAG_JUDGE_MODEL=...
# CODERAG_EMBED_MODEL=jinaai/jina-embeddings-v2-base-code
# CODERAG_EMBED_TRUST_REMOTE_CODE=1
# CODERAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# CODERAG_INDEX_DIR=.coderag_index

# --- Resilience / ops (defaults keep the SDK's own behavior) ---
# CODERAG_LLM_TIMEOUT=120          # seconds per LLM request (bounds hangs)
# CODERAG_LLM_MAX_RETRIES=3        # SDK exponential backoff on 429/5xx/timeouts
# CODERAG_LOG_LEVEL=INFO           # DEBUG|INFO|WARNING|ERROR (default WARNING)

# --- Vector backend (default 'exact' = brute-force, exact) ---
# CODERAG_VECTOR_BACKEND=hnsw      # approximate ANN for large indexes (pip install 'coderag[ann]')
# CODERAG_HNSW_EF=128              # query-time accuracy/speed knob (higher = more recall, slower)

// FastAPI golden question set (outline §6.1). One JSON object per line; lines
// starting with // are ignored by the loader.
//
// relevant_files are RELATIVE TO INDEXING THE PACKAGE DIRECTORY:
//     python -m coderag.cli index fastapi/fastapi
// (so paths are e.g. "routing.py", "dependencies/utils.py"). If you index the
// repo root instead, prefix each with "fastapi/".
//
// Every relevant_files / relevant_symbols entry below was verified against the
// FastAPI source (grep), not guessed. 16 questions spanning factual / how-to /
// where / cross-file / out-of-scope; ~4 marked holdout. Extend to 30-50 for a
// fuller eval, and adjust if the FastAPI version you cloned has moved code.
//
// Schema: id, question, type, relevant_files, relevant_symbols (optional),
//         reference_answer (optional), holdout (optional).
{"id": "q001", "question": "How does FastAPI coerce a path or query parameter to its declared type, and what happens on an invalid value?", "type": "how-to", "relevant_files": ["dependencies/utils.py", "exceptions.py"], "relevant_symbols": ["analyze_param", "request_params_to_args", "RequestValidationError"], "reference_answer": "Parameters declared with type hints become Pydantic fields (analyze_param); request_params_to_args validates/coerces incoming values against them, and an invalid value collects into a RequestValidationError, which maps to a 422 response."}
{"id": "q002", "question": "Where is a route added to an APIRouter?", "type": "where", "relevant_files": ["routing.py"], "relevant_symbols": ["APIRouter.add_api_route", "APIRoute"], "reference_answer": "APIRouter.add_api_route builds an APIRoute and appends it to self.routes."}
{"id": "q003", "question": "What exception represents a request validation failure and what status code does it produce?", "type": "factual", "relevant_files": ["exceptions.py", "exception_handlers.py"], "relevant_symbols": ["RequestValidationError", "request_validation_exception_handler"], "reference_answer": "RequestValidationError is raised; request_validation_exception_handler turns it into a 422 Unprocessable Entity JSON response."}
{"id": "q004", "question": "How are sub-dependencies resolved for an incoming request?", "type": "cross-file", "relevant_files": ["dependencies/utils.py", "routing.py"], "relevant_symbols": ["get_dependant", "solve_dependencies", "get_request_handler"], "reference_answer": "get_dependant builds a dependency tree from the endpoint signature; solve_dependencies resolves it recursively per request (caching results), and it is invoked from the handler returned by get_request_handler.", "holdout": true}
{"id": "q005", "question": "How does FastAPI convert arbitrary objects like Pydantic models and datetimes into JSON-serializable data?", "type": "how-to", "relevant_files": ["encoders.py"], "relevant_symbols": ["jsonable_encoder"], "reference_answer": "jsonable_encoder recursively converts objects (Pydantic models, dataclasses, datetimes, etc.) into JSON-compatible Python types."}
{"id": "q006", "question": "Where is the OpenAPI schema for the application generated?", "type": "where", "relevant_files": ["openapi/utils.py"], "relevant_symbols": ["get_openapi"], "reference_answer": "get_openapi builds the OpenAPI schema dict from the app's routes."}
{"id": "q007", "question": "What function declares a dependency for a path operation?", "type": "factual", "relevant_files": ["param_functions.py"], "relevant_symbols": ["Depends"], "reference_answer": "Depends() marks a callable as a dependency to be resolved and injected."}
{"id": "q008", "question": "How do I declare a query parameter with validation constraints and metadata?", "type": "how-to", "relevant_files": ["param_functions.py"], "relevant_symbols": ["Query"], "reference_answer": "Query() returns a parameter descriptor (FieldInfo) carrying defaults and validation constraints for a query parameter."}
{"id": "q009", "question": "How does an incoming HTTP request flow to calling my endpoint function?", "type": "cross-file", "relevant_files": ["routing.py", "dependencies/utils.py"], "relevant_symbols": ["get_request_handler", "solve_dependencies", "serialize_response"], "reference_answer": "get_request_handler returns the ASGI handler for a route: it solves dependencies (solve_dependencies), calls the endpoint, then serializes the result (serialize_response) into a response.", "holdout": true}
{"id": "q010", "question": "What class is raised to return an HTTP error with a status code and detail message?", "type": "factual", "relevant_files": ["exceptions.py"], "relevant_symbols": ["HTTPException"], "reference_answer": "HTTPException(status_code, detail) is raised to return an HTTP error response."}
{"id": "q011", "question": "Where is OAuth2 bearer-token extraction from the Authorization header implemented?", "type": "where", "relevant_files": ["security/oauth2.py"], "relevant_symbols": ["OAuth2PasswordBearer"], "reference_answer": "OAuth2PasswordBearer extracts the Bearer token from the Authorization header and is used as a dependency."}
{"id": "q012", "question": "What response class uses orjson for faster JSON serialization?", "type": "factual", "relevant_files": ["responses.py"], "relevant_symbols": ["ORJSONResponse"], "reference_answer": "ORJSONResponse renders responses using orjson.", "holdout": true}
{"id": "q013", "question": "How does a route validate and serialize its return value against response_model?", "type": "how-to", "relevant_files": ["routing.py"], "relevant_symbols": ["serialize_response", "APIRoute", "get_request_handler"], "reference_answer": "APIRoute builds a response field from response_model; the handler from get_request_handler calls serialize_response, which validates and filters the return value through that field."}
{"id": "q014", "question": "How does FastAPI avoid calling the same dependency twice within one request?", "type": "cross-file", "relevant_files": ["dependencies/utils.py"], "relevant_symbols": ["solve_dependencies"], "reference_answer": "solve_dependencies maintains a dependency_cache keyed by the dependency callable (and security scopes); a cached result is reused instead of re-calling the dependency.", "holdout": true}
{"id": "q015", "question": "What is the default database connection pool size in FastAPI?", "type": "out-of-scope", "relevant_files": [], "reference_answer": "Out of scope — FastAPI does not manage database connections or pools; the system should abstain rather than guess."}
{"id": "q016", "question": "How do I configure built-in Redis caching in FastAPI core?", "type": "out-of-scope", "relevant_files": [], "reference_answer": "Out of scope — FastAPI core has no built-in Redis caching; the system should abstain."}
{"id": "q017", "question": "Where is the ASGI app for a WebSocket route built?", "type": "where", "relevant_files": ["routing.py"], "relevant_symbols": ["get_websocket_app", "APIWebSocketRoute"], "reference_answer": "get_websocket_app builds the WebSocket handler (solving dependencies), and APIWebSocketRoute wires it into the router.", "holdout": true}
{"id": "q018", "question": "What class represents an uploaded file?", "type": "factual", "relevant_files": ["datastructures.py"], "relevant_symbols": ["UploadFile"], "reference_answer": "UploadFile (extending Starlette's) represents a multipart upload with filename, content_type, and a spooled file object."}
{"id": "q019", "question": "How do I declare a form-encoded field parameter?", "type": "how-to", "relevant_files": ["param_functions.py"], "relevant_symbols": ["Form"], "reference_answer": "Form() marks a parameter as coming from form-encoded request data."}
{"id": "q020", "question": "How do I declare a file upload parameter in an endpoint?", "type": "how-to", "relevant_files": ["param_functions.py"], "relevant_symbols": ["File"], "reference_answer": "File() marks a parameter as a multipart file upload (typically typed UploadFile)."}
{"id": "q021", "question": "What function explicitly declares a request body parameter?", "type": "factual", "relevant_files": ["param_functions.py"], "relevant_symbols": ["Body"], "reference_answer": "Body() declares a parameter that is read from the request body."}
{"id": "q022", "question": "Where are header and cookie parameters declared?", "type": "where", "relevant_files": ["param_functions.py"], "relevant_symbols": ["Header", "Cookie"], "reference_answer": "Header() and Cookie() in param_functions.py declare parameters sourced from request headers and cookies."}
{"id": "q023", "question": "How does the OAuth2 password flow read the username and password from the request?", "type": "cross-file", "relevant_files": ["security/oauth2.py"], "relevant_symbols": ["OAuth2PasswordRequestForm"], "reference_answer": "OAuth2PasswordRequestForm declares username, password, scope, etc. as form fields and is used as a dependency to parse the login form.", "holdout": true}
{"id": "q024", "question": "Where is API key authentication via a request header implemented?", "type": "where", "relevant_files": ["security/api_key.py"], "relevant_symbols": ["APIKeyHeader"], "reference_answer": "APIKeyHeader reads the API key from a named request header."}
{"id": "q025", "question": "What security class extracts an HTTP Bearer token from the Authorization header?", "type": "factual", "relevant_files": ["security/http.py"], "relevant_symbols": ["HTTPBearer"], "reference_answer": "HTTPBearer parses the 'Authorization: Bearer <token>' header."}
{"id": "q026", "question": "How is the Swagger UI HTML documentation page generated?", "type": "how-to", "relevant_files": ["openapi/docs.py"], "relevant_symbols": ["get_swagger_ui_html"], "reference_answer": "get_swagger_ui_html returns an HTMLResponse embedding Swagger UI configured to load the app's openapi.json.", "holdout": true}
{"id": "q027", "question": "What handler converts an HTTPException into an HTTP response?", "type": "factual", "relevant_files": ["exception_handlers.py"], "relevant_symbols": ["http_exception_handler"], "reference_answer": "http_exception_handler turns an HTTPException into a JSONResponse with the exception's status code and detail.", "holdout": true}
{"id": "q028", "question": "Where can I schedule work to run after the response is sent?", "type": "where", "relevant_files": ["background.py"], "relevant_symbols": ["BackgroundTasks"], "reference_answer": "BackgroundTasks (re-exported from Starlette) schedules callables to run after the response is returned."}
{"id": "q029", "question": "How does an APIRoute build the per-request handler that validates the return value?", "type": "cross-file", "relevant_files": ["routing.py"], "relevant_symbols": ["APIRoute.get_route_handler", "get_request_handler", "serialize_response"], "reference_answer": "APIRoute.get_route_handler returns the handler from get_request_handler, which solves dependencies, calls the endpoint, and validates/serializes the result via serialize_response.", "holdout": true}
{"id": "q030", "question": "What classes back the different parameter kinds like query, path, and header?", "type": "factual", "relevant_files": ["params.py"], "relevant_symbols": ["Param", "ParamTypes"], "reference_answer": "params.py defines ParamTypes and the Param subclasses (Query, Path, Header, Cookie, Body) that describe each parameter kind.", "holdout": true}
